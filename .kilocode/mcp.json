{
	"mcpServers": {
		"cloudflareObserve": {
			"command": "npx",
			"args": ["mcp-remote", "https://observability.mcp.cloudflare.com/sse"]
		},
		"cloudflareDocs": {
			"command": "npx",
			"args": ["mcp-remote", "https://docs.mcp.cloudflare.com/sse"]
		},
		"mermaid": {
			"command": "npx",
			"args": ["-y", "mcp-remote", "https://mcp.mermaid.ai/mcp"]
		}
	}
}
