{
	"name": "ration",
	"version": "1.5.65",
	"private": true,
	"license": "SEE LICENSE IN LICENSE",
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"cf-typegen": "wrangler types",
		"deploy": "bun run build && wrangler deploy build/server/index.js",
		"dev": "RATION_DEV_MODE=local react-router dev",
		"dev:local": "RATION_DEV_MODE=local react-router dev",
		"dev:remote": "RATION_DEV_MODE=dev CLOUDFLARE_ENV=dev react-router dev",
		"ios:generate": "cd ios && xcodegen generate",
		"ios:build": "bash scripts/ios-build.sh",
		"ios:density": "bun scripts/export-ios-density.ts",
		"ios:test": "bash scripts/ios-test.sh",
		"ios:check": "bash scripts/ios-check.sh",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"flag:check": "bun scripts/flag-check.ts",
		"postinstall": "bun scripts/postinstall.ts",
		"pretest:unit": "bun scripts/verify-test-deps.ts",
		"pretest:e2e": "bun scripts/e2e-prep-local.ts",
		"preview": "bun run build && vite preview",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:report": "playwright show-report",
		"typecheck": "bun run cf-typegen && react-router typegen && tsc -b",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply ration-db-dev --local --config wrangler.local.jsonc",
		"db:reset:local": "bun scripts/e2e-prep-local.ts --force-reset",
		"db:migrate:dev": "wrangler d1 migrations apply ration-db-dev --remote --env dev",
		"db:migrate:prod": "wrangler d1 migrations apply DB --remote",
		"dev:mcp": "wrangler dev --config wrangler.mcp.jsonc --env dev",
		"deploy:mcp": "wrangler deploy --config wrangler.mcp.jsonc --env=''",
		"dev:copilot": "wrangler dev --config wrangler.copilot.jsonc --env dev",
		"deploy:copilot": "wrangler deploy --config wrangler.copilot.jsonc --env=''"
	},
	"dependencies": {
		"@ai-sdk/react": "^3",
		"@better-auth/oauth-provider": "1.6.23",
		"@cloudflare/ai-chat": "^0.9.3",
		"@cloudflare/think": "^0.12.1",
		"@fontsource/space-mono": "^5.2.9",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@react-router/cloudflare": "^7.14.2",
		"@stripe/react-stripe-js": "^5.6.1",
		"@stripe/stripe-js": "^8.11.0",
		"agents": "^0.17.3",
		"ai": "^6",
		"better-auth": "1.6.23",
		"drizzle-orm": "^0.45.2",
		"gray-matter": "^4.0.3",
		"isbot": "^5.1.39",
		"jose": "^6.1.3",
		"lucide-react": "^0.576.0",
		"mermaid": "^11.16.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-markdown": "^10.1.0",
		"react-router": "^7.14.2",
		"react-syntax-highlighter": "^16.1.1",
		"remark-gfm": "^4.0.1",
		"stripe": "^20.4.1",
		"workers-ai-provider": "^3.3.1",
		"zod": "^4.3.6",
		"zod-to-json-schema": "^3.25.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@cloudflare/vite-plugin": "^1.40.2",
		"@playwright/test": "^1.59.1",
		"@react-router/dev": "^7.14.2",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^22.19.17",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@vitest/coverage-v8": "4.1.5",
		"drizzle-kit": "^0.31.10",
		"esbuild": "^0.27.2",
		"obug": "2.1.1",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3",
		"vite": "^7.3.2",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.5",
		"wrangler": "^4.100.0"
	},
	"overrides": {
		"@hono/node-server": "1.19.14",
		"defu": "6.1.7",
		"effect": "^3.20.0",
		"esbuild": "^0.27.2",
		"express-rate-limit": "8.2.2",
		"hono": "4.12.14",
		"kysely": "0.28.16",
		"lodash": "4.18.1",
		"path-to-regexp": "8.4.0",
		"picomatch": "4.0.4",
		"qs": "6.14.2",
		"rollup": "^4.60.2",
		"undici": "^7.25.0",
		"vite": "7.3.2"
	}
}
