{
	"name": "ration",
	"version": "1.0.42",
	"private": true,
	"license": "SEE LICENSE IN LICENSE",
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"cf-typegen": "wrangler types",
		"deploy": "bun run build && wrangler deploy build/server/index.js",
		"dev": "CLOUDFLARE_ENV=dev react-router dev",
		"dev:remote": "CLOUDFLARE_ENV=dev react-router dev",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"postinstall": "bun run cf-typegen",
		"preview": "bun run build && vite preview",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:report": "playwright show-report",
		"typecheck": "bun run cf-typegen && react-router typegen && tsc -b",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:migrate:dev": "wrangler d1 migrations apply ration-db-dev --remote --env dev",
		"db:migrate:prod": "wrangler d1 migrations apply DB --remote",
		"dev:mcp": "wrangler dev --config wrangler.mcp.jsonc --env dev",
		"deploy:mcp": "wrangler deploy --config wrangler.mcp.jsonc --env=''"
	},
	"dependencies": {
		"@better-auth/cli": "1.4.21",
		"@fontsource/space-mono": "^5.2.9",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@react-router/cloudflare": "^7.13.1",
		"@stripe/react-stripe-js": "^5.6.1",
		"@stripe/stripe-js": "^8.9.0",
		"agents": "^0.7.2",
		"better-auth": "1.4.21",
		"drizzle-orm": "^0.45.1",
		"isbot": "^5.1.35",
		"lucide-react": "^0.576.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.13.1",
		"stripe": "^20.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@cloudflare/vite-plugin": "^1.26.0",
		"@playwright/test": "^1.58.2",
		"@react-router/dev": "^7.13.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^22",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.1.9",
		"drizzle-kit": "^0.31.9",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.2",
		"vite": "^7.1.7",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.0.18",
		"wrangler": "^4.69.0"
	}
}
