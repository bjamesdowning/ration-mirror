{
	"name": "ration",
	"version": "0.9.4-ALPHA",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"cf-typegen": "wrangler types",
		"deploy": "bun run build && wrangler deploy build/server/index.js",
		"dev": "react-router dev",
		"dev:wrangler": "wrangler dev",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"postinstall": "bun run cf-typegen",
		"preview": "bun run build && vite preview",
		"test:unit": "vitest run",
		"typecheck": "bun run cf-typegen && react-router typegen && tsc -b",
		"db:generate": "drizzle-kit generate",
		"db:migrate:dev": "wrangler d1 migrations apply DB --local",
		"db:migrate:prod": "wrangler d1 migrations apply DB --remote"
	},
	"dependencies": {
		"@better-auth/cli": "^1.4.15",
		"@fontsource/space-mono": "^5.2.9",
		"@react-router/cloudflare": "^7.12.0",
		"@stripe/react-stripe-js": "^5.4.1",
		"@stripe/stripe-js": "^8.6.3",
		"better-auth": "^1.4.15",
		"drizzle-orm": "^0.45.1",
		"isbot": "^5.1.31",
		"lucide-react": "^0.562.0",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-router": "7.12.0",
		"stripe": "^20.2.0",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@cloudflare/vite-plugin": "^1.13.5",
		"@react-router/dev": "7.12.0",
		"@tailwindcss/vite": "^4.1.13",
		"@types/node": "^22",
		"@types/react": "^19.1.13",
		"@types/react-dom": "^19.1.9",
		"drizzle-kit": "^0.31.8",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.2",
		"vite": "^7.1.7",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^4.0.17",
		"wrangler": "^4.63.0"
	}
}
