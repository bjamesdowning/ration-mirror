{
	"extends": "./tsconfig.json",
	"include": [
		"vite.config.ts",
		"drizzle.config.ts",
		"react-router.config.ts",
		"vitest.config.ts"
	],
	"exclude": ["node_modules", "node_modules.nosync"],
	"compilerOptions": {
		"composite": true,
		"strict": true,
		"allowJs": false,
		"checkJs": false,
		"types": ["node"],
		"lib": ["ES2022"],
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler"
	}
}
