/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ration",
	"compatibility_date": "2026-01-17",
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": ["nodejs_compat"],
	"vars": {
		"BETTER_AUTH_URL": "https://ration.mayutic.com"
	},
	/**
	 * Smart Placement
	 * https://developers.cloudflare.com/workers/configuration/smart-placement/#smart-placement
	 */
	"placement": {
		"mode": "smart"
	},
	/**
	 * Bindings
	 * Bindings allow your Worker to interact with resources on the Cloudflare Developer Platform, including
	 * databases, object storage, AI inference, real-time communication and more.
	 * https://developers.cloudflare.com/workers/runtime-apis/bindings/
	 */
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "ration-db",
			"database_id": "41e98836-d752-4bbe-a14f-68e802c72c10",
			"migrations_dir": "drizzle"
		}
	],
	"vectorize": [
		{
			"binding": "VECTOR_INDEX",
			"index_name": "ration-index"
		}
	],
	"r2_buckets": [
		{
			"binding": "STORAGE",
			"bucket_name": "ration-storage"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"kv_namespaces": [
		{
			"binding": "RATION_KV",
			"id": "afafb8640ed44b6e9cfe5df204eb6a74",
			"preview_id": "f00538f983d84810b478a6050a214963"
		}
	],
	/**
	 * KV Namespace Setup Instructions:
	 * 1. Create production namespace: wrangler kv namespace create "RATION_KV"
	 * 2. Create preview namespace: wrangler kv namespace create "RATION_KV" --preview
	 * 3. Replace PLACEHOLDER_PRODUCTION_ID and PLACEHOLDER_PREVIEW_ID with actual IDs
	 *
	 * Secrets (set via CLI, not in this file)
	 * Run: wrangler secret put <SECRET_NAME>
	 * Required secrets:
	 *   - STRIPE_SECRET_KEY: Stripe server-side API key
	 *   - STRIPE_PUBLISHABLE_KEY: Stripe client-side key
	 *   - STRIPE_WEBHOOK_SECRET: Stripe webhook signing secret
	 *   - BETTER_AUTH_SECRET: Better Auth encryption key
	 *   - ADMIN_EMAILS: Comma-separated admin emails
	 */
	/*
	 * Static Assets
	 * https://developers.cloudflare.com/workers/static-assets/binding/
	 */
	"assets": {
		"directory": "./build/client",
		"binding": "ASSETS"
	},
	"routes": [
		{
			"pattern": "ration.mayutic.com",
			"custom_domain": true
		}
	]
}
