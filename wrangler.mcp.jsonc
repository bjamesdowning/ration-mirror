{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ration-mcp",
	"main": "workers/mcp.ts",
	"compatibility_date": "2026-03-01",
	"compatibility_flags": ["nodejs_compat"],
	"routes": [
		{
			"pattern": "mcp.ration.mayutic.com",
			"custom_domain": true
		}
	],
	"placement": {
		"mode": "smart"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "ration-db",
			"database_id": "41e98836-d752-4bbe-a14f-68e802c72c10"
		}
	],
	"r2_buckets": [
		{
			"binding": "STORAGE",
			"bucket_name": "ration-storage"
		}
	],
	"kv_namespaces": [
		{
			"binding": "RATION_KV",
			"id": "afafb8640ed44b6e9cfe5df204eb6a74"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"vectorize": [
		{
			"binding": "VECTORIZE",
			"index_name": "ration-cargo"
		}
	],
	"env": {
		"dev": {
			// All bindings use "remote: true" so local worker code calls the real
			// dev-tier resources on Cloudflare's network (Remote Bindings, GA Sep 2025).
			// This replaces the deprecated "wrangler dev --remote" approach which
			// required the custom domain to already be deployed.
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "ration-db-dev",
					"database_id": "eec9f2f0-5d34-4392-89dd-317f373bf1e9",
					"remote": true
				}
			],
			"r2_buckets": [
				{
					"binding": "STORAGE",
					"bucket_name": "ration-storage-dev",
					"remote": true
				}
			],
			"kv_namespaces": [
				{
					"binding": "RATION_KV",
					"id": "060a0f82bdff4a95a89ded794f877ad7",
					"remote": true
				}
			],
			// Vectorize and AI are not inherited by environments — must be repeated
			"vectorize": [
				{
					"binding": "VECTORIZE",
					"index_name": "ration-cargo",
					"remote": true
				}
			],
			"ai": {
				"binding": "AI",
				"remote": true
			}
		}
	}
}
